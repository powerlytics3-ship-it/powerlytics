# ─── API CONNECTION ───────────────────────────────────────────────────────────
# URL of the NestJS API (apps/api)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# URL where Better Auth is mounted (same as the API URL)
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:4000"

# ─── SENTRY (Frontend Error Tracking — optional) ──────────────────────────────
# Get from: https://sentry.io → Create Project → Next.js → DSN
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"

# ─── ANALYTICS (PostHog — optional) ──────────────────────────────────────────
# Get from: https://posthog.com → Project Settings → API key
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
