# ─── DATABASE (Neon PostgreSQL) ───────────────────────────────────────────────
# Get from: https://neon.tech → Create project → Connection string
# Pooled URL is for the app (PgBouncer), Direct URL is for migrations only
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── BETTER AUTH ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-super-secret-random-string-min-32-chars"
# Your API URL (where NestJS runs)
BETTER_AUTH_URL="http://localhost:4000"

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Add authorized redirect URI: http://localhost:4000/api/auth/callback/google
GOOGLE_CLIENT_ID="123456789-xxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxx"

# ─── UPSTASH REDIS (BullMQ + Rate Limiting) ───────────────────────────────────
# Get from: https://upstash.com → Create Redis database → REST API tab
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── RESEND (Transactional Email) ─────────────────────────────────────────────
# Get from: https://resend.com → API Keys → Create API Key
# Also add and verify your sending domain at: https://resend.com/domains
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ─── BRIDGE SERVICE ───────────────────────────────────────────────────────────
# ⚠️  REQUIRED — app will NOT start without these
# The bridge is the MQTT-to-HTTPS gateway that communicates with physical devices
# Get these values from your bridge service operator
BRIDGE_BASE_URL="https://bridge.yourdomain.com"
BRIDGE_API_TOKEN="your-bridge-api-token"
# Shared secret for HMAC-SHA256 signing of bridge callbacks
# Generate with: openssl rand -hex 32
BRIDGE_HMAC_SECRET="your-bridge-hmac-shared-secret"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
# Production: "https://app.yourdomain.com,https://admin.yourdomain.com"

# ─── SENTRY (Error Tracking) ──────────────────────────────────────────────────
# Get from: https://sentry.io → Create Project → Node.js → DSN
SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"

# ─── CLOUDFLARE R2 (Object Storage — optional, for CSV exports) ───────────────
# Get from: https://dash.cloudflare.com → R2 → Create bucket + API token
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="powerlytic-exports"

# ─── OPERATIONAL TUNING ───────────────────────────────────────────────────────
# How long to wait for a bridge deployment ack before marking TIMED_OUT (seconds)
DEPLOYMENT_TIMEOUT_SECONDS=300

# ─── RUNTIME ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
