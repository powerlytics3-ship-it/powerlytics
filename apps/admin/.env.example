# ─── API CONNECTION ───────────────────────────────────────────────────────────
# URL of the NestJS API (apps/api) — same as web app
NEXT_PUBLIC_API_URL="http://localhost:4000"

# URL where Better Auth is mounted
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:4000"

# ─── SENTRY (optional) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"
