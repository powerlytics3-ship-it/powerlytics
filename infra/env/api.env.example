API_PORT=4000
# TODO: set this to your real Postgres/Timescale connection string.
DATABASE_URL=postgresql://powerlytic:powerlytic@postgres:5432/powerlytic
# TODO: set this to your real Redis URL.
REDIS_URL=redis://redis:6379
# TODO: set this to your real MQTT broker URL.
MQTT_URL=mqtt://mosquitto:1883
MQTT_ENABLED=false
MQTT_USERNAME=
MQTT_PASSWORD=
# TODO: set AUTH_REQUIRED=true only after your OIDC provider is configured.
AUTH_REQUIRED=false
# TODO: set these to your real OIDC issuer and API audience.
OIDC_ISSUER_URL=http://keycloak:8080/realms/powerlytic
OIDC_AUDIENCE=powerlytic-api
# TODO: set this to your bridge URL if config delivery is HTTP-based.
CONFIG_BRIDGE_URL=http://bridge:4100/c2d/commands
CONFIG_BRIDGE_TOKEN=
# TODO: set true for direct API -> EMQX wrapper HTTPS config delivery.
CONFIG_BRIDGE_DIRECT=false
# TODO: set this to a real secret-manager/KMS value before provisioning devices.
DEVICE_API_KEY_PEPPER=replace-with-kms-secret
# TODO: set prisma after migrations/seeds are applied.
POWERLYTIC_DATA_MODE=demo
# TODO: set true after Redis and worker are running.
QUEUE_ENABLED=false
