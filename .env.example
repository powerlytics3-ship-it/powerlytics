NODE_ENV=development
API_PORT=4000
WEB_PORT=3000

# TODO: set this to your deployed API base URL for the frontend.
PUBLIC_API_BASE_URL=http://localhost:4000/api

# TODO: set this to your production Postgres/Timescale connection string.
DATABASE_URL=postgresql://powerlytic:powerlytic@localhost:5432/powerlytic

# TODO: set this to your production Redis URL used by BullMQ.
REDIS_URL=redis://localhost:6379

# TODO: set this to your MQTT broker URL if devices use MQTT.
MQTT_URL=mqtt://localhost:1883
MQTT_ENABLED=false
# TODO: add MQTT_USERNAME/MQTT_PASSWORD when broker authentication is enabled.
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=powerlytic-api

# TODO: set AUTH_REQUIRED=true after OIDC is configured and seeded users/memberships exist.
AUTH_REQUIRED=false

# TODO: set these from your Keycloak/Auth0/Cognito OIDC app.
OIDC_ISSUER_URL=http://localhost:8080/realms/powerlytic
OIDC_AUDIENCE=powerlytic-api
OIDC_CLIENT_ID=powerlytic-web
OIDC_CLIENT_SECRET=change-me

# TODO: replace with a secret-manager/KMS value before provisioning real device API keys.
DEVICE_API_KEY_PEPPER=replace-with-kms-secret

# TODO: set this when using an HTTP bridge for config/actuation delivery.
CONFIG_BRIDGE_URL=http://localhost:4100/c2d/commands
CONFIG_BRIDGE_TOKEN=
# TODO: set true if your EMQX wrapper exposes HTTPS and you want API to call it directly on config deploy.
CONFIG_BRIDGE_DIRECT=false

# TODO: set POWERLYTIC_DATA_MODE=prisma after DATABASE_URL is ready and migrations/seeds are run.
POWERLYTIC_DATA_MODE=demo

# TODO: set QUEUE_ENABLED=true after REDIS_URL is ready and the worker is running.
QUEUE_ENABLED=false
WEB_ORIGIN=http://localhost:3000
