{
  "name": "@powerlytic/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "DATABASE_URL=${DATABASE_URL:-postgresql://powerlytic:powerlytic@localhost:5432/powerlytic} prisma db push --schema prisma/schema.prisma",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://powerlytic:powerlytic@localhost:5432/powerlytic} prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "DATABASE_URL=${DATABASE_URL:-postgresql://powerlytic:powerlytic@localhost:5432/powerlytic} tsx prisma/seed.ts",
    "lint": "DATABASE_URL=${DATABASE_URL:-postgresql://powerlytic:powerlytic@localhost:5432/powerlytic} prisma validate --schema prisma/schema.prisma",
    "test": "echo \"db: no tests\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
